parameters:
    level: 5
    paths:
        - src
        - tests
    scanDirectories:
        - vendor
    bootstrapFiles:
        - vendor/autoload.php
    ignoreErrors:
        - '#Parameter \#1 \$server of method Upscale\\\\Swoole\\\\Blackfire\\\\Profiler::instrument\(\) expects Swoole\\\\Http\\\\Server, OpenSwoole\\\\Http\\\\Server\|null given\.#'

